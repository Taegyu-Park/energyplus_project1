! ==========================================
! BIPV ELECTRIC LOAD CENTER: INVERTER
! ==========================================

ElectricLoadCenter:Inverter:Simple,
    Main_Inverter,                !- Name
    ,                             !- Availability Schedule Name
    ,                             !- Zone Name
    0.0,                          !- Radiative Fraction
    0.96;                         !- Efficiency

! ==========================================
! BIPV ELECTRIC LOAD CENTER: DISTRIBUTION
! ==========================================

ElectricLoadCenter:Distribution,
    BIPV Load Center,             !- Name
    BIPV Generators,              !- Generator List Name
    Baseload,                     !- Generator Operation Scheme Type
    0.0,                          !- Demand Limit Scheme Purchased Electric Demand Limit {W}
    ,                             !- Track Schedule Name Scheme Name
    ,                             !- Track Meter Scheme Name Meter Name
    DirectCurrentWithInverter,    !- Electrical Buss Type
    Main_Inverter;                !- Inverter Name

! ==========================================
! PYTHON PLUGIN REGISTRATION AND OUTPUT VARIABLES
! ==========================================

PythonPlugin:SearchPaths,
    Yes,                          !- Add Current Working Directory to Search Path
    Yes,                          !- Add Input File Directory to Search Path
    ;                             !- Search Path 1

PythonPlugin:Instance,
    KineticBIPVPlugin,            !- Name
    Yes,                          !- Run During Warmup Days
    model_pythonpluginsystem,     !- Module Name
    KineticBIPVPlugin;

PythonPlugin:Variables,
    BIPV_Vars,                    !- Name
    BIPV_Tilt_Angle,              !- Variable Name 1
    BIPV_Incident_Solar,          !- Variable Name 2
    BIPV_Power_Generation,        !- Variable Name 3
    BIPV_Efficiency;              !- Variable Name 4

PythonPlugin:OutputVariable,
    BIPV_Tilt_Angle,              !- Name
    BIPV_Tilt_Angle,              !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    deg;                          !- Units

PythonPlugin:OutputVariable,
    BIPV_Incident_Solar,          !- Name
    BIPV_Incident_Solar,          !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    W/m2;                         !- Units

PythonPlugin:OutputVariable,
    BIPV_Power_Generation,        !- Name
    BIPV_Power_Generation,        !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    W;                            !- Units

PythonPlugin:OutputVariable,
    BIPV_Efficiency,              !- Name
    BIPV_Efficiency,              !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    ;                             !- Units

! ==========================================
! ESSENTIAL OUTPUT VARIABLES FOR PYTHON PLUGIN SENSORS
! ==========================================

Output:Variable,
    *,                            !- Key Value
    Site Direct Solar Radiation Rate per Area,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Diffuse Solar Radiation Rate per Area,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Outdoor Air Drybulb Temperature,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Solar Altitude Angle,    !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Solar Azimuth Angle,     !- Variable Name
    Timestep;                     !- Reporting Frequency

