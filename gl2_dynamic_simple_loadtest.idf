! ═══════════════════════════════════════════════════════════════
! Kinetic BIPV 태양 추적 시스템 - 추가 객체들
! ═══════════════════════════════════════════════════════════════
! ─── 구형 BIPV 투과율 스케줄 소거 (10개 각도 이진 제어로 불필요) ───

! ─── 주광 제어 참조점 (실내 작업면 높이) ───
!
! Daylighting:ReferencePoint,
!     DaylightRefPt1,               !- Name
!     glazing_thermal_zone,         !- Zone or Space Name
!     1.5,                          !- X-Coordinate of Reference Point {m}
!     1.5,                          !- Y-Coordinate of Reference Point {m}
!     0.8;                          !- Z-Coordinate of Reference Point {m}
!
! ─── 주광 제어 (조명 부하 연동 - 연속 디밍) ───
!
! Daylighting:Controls,
!     Daylight Control 1,           !- Name
!     glazing_thermal_zone,         !- Zone or Space Name
!     SplitFlux,                    !- Daylighting Method
!     ,                             !- Availability Schedule Name
!     Continuous,                   !- Lighting Control Type
!     0.3,                          !- Minimum Input Power Fraction for Continuous or ContinuousOff Dimming Control
!     0.2,                          !- Minimum Light Output Fraction for Continuous or ContinuousOff Dimming Control
!     ,                             !- Number of Stepped Control Steps
!     ,                             !- Probability Lighting will be Reset When Needed in Manual Stepped Control
!     DaylightRefPt1,               !- Glare Calculation Daylighting Reference Point Name
!     180,                          !- Glare Calculation Azimuth Angle of View Direction Clockwise from Zone y-Axis {deg}
!     22,                           !- Maximum Allowable Discomfort Glare Index
!     ,                             !- DElight Gridding Resolution {m2}
!     DaylightRefPt1,               !- Daylighting Reference Point 1 Name
!     1.0,                          !- Fraction of Lights Controlled by Reference Point 1
!     500;                          !- Illuminance Setpoint at Reference Point 1 {lux}

! ─── Python Plugin 설정 ───

PythonPlugin:SearchPaths,
    Yes,                          !- Add Current Working Directory to Search Path
    Yes;                          !- Add Input File Directory to Search Path

PythonPlugin:Instance,
    KineticBIPVPlugin,            !- Name
    Yes,                          !- Run During Warmup Days
    kinetic_bipv_simple_loadtest,          !- Module Name
    KineticBIPVPlugin;            !- Class Name

PythonPlugin:Variables,
    BIPV_Vars,                    !- Name
    BIPV_Tilt_Angle,              !- Variable Name 1
    BIPV_Incident_Solar,          !- Variable Name 2
    BIPV_Power_Generation;        !- Variable Name 3

! ─── Plugin 출력 변수 선언 ───

PythonPlugin:OutputVariable,
    BIPV_Tilt_Angle,              !- Name
    BIPV_Tilt_Angle,              !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    deg;                          !- Units

PythonPlugin:OutputVariable,
    BIPV_Incident_Solar,          !- Name
    BIPV_Incident_Solar,          !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    W/m2;                         !- Units

PythonPlugin:OutputVariable,
    BIPV_Power_Generation,        !- Name
    BIPV_Power_Generation,        !- Python Plugin Variable Name
    Averaged,                     !- Type of Data in Variable
    ZoneTimestep,                 !- Update Frequency
    W;                            !- Units

! ─── 출력 변수 (태양 위치 + BIPV 추적 + 조명) ───

Output:Variable,
    *,                            !- Key Value
    Site Solar Altitude Angle,    !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Solar Azimuth Angle,     !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Direct Solar Radiation Rate per Area,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    *,                            !- Key Value
    Site Diffuse Solar Radiation Rate per Area,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    BIPV_Tilt_Angle,              !- Key Value
    PythonPlugin:OutputVariable,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    BIPV_Incident_Solar,          !- Key Value
    PythonPlugin:OutputVariable,  !- Variable Name
    Timestep;                     !- Reporting Frequency

Output:Variable,
    BIPV_Power_Generation,        !- Key Value
